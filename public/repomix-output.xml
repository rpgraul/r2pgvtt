    copied = false;
  }, 2000);
}

const isDeleted = $derived(!!game.deleted_at);
const isNarrator = userRole === 'narrador';
const canInvite = $derived(userRole === 'narrador' || userRole === 'assistente');
const showCopyLink = $derived(!!game.invite_code && !isDeleted && canInvite);
</script>

