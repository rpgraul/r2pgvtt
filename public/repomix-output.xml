    <button
      type="button"
      class="text-sm text-muted-foreground hover:text-foreground"
      onclick={() => {
        isLogin = !isLogin;
        error = '';
      }}
    >
      {isLogin ? 'Não tem conta? Criar' : 'Já tem conta? Entrar'}
    </button>
  </div>
</form>
