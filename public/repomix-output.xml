  {#if error}
    <p class="text-sm text-destructive">{error}</p>
  {/if}
  
  <div class="flex flex-col gap-2">
    <Button type="submit" disabled={loading} class="w-full">
      {loading ? 'Carregando...' : isLogin ? 'Entrar' : 'Criar Conta'}
