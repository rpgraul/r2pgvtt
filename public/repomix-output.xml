import { Search } from 'lucide-svelte';
import { onDestroy } from 'svelte';

let searchValue = $state('');

onDestroy(() => {
  if (debounceTimer) clearTimeout(debounceTimer);
});
let debounceTimer = null;

function handleInput(e) {
  searchValue = e.target.value;

  if (debounceTimer) clearTimeout(debounceTimer);

