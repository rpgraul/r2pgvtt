    settings: Settings,
    'bulk-edit': ListChecks,
    converter: Layers,
    help: HelpCircle,
    chat: MessageCircle,
    audio: Music,
    dice: Dices,
    'add-card': Plus,
    'sheet-mode': IdCard,
    'drawing-mode': Palette,
  };
  return icons[key];
}
